# 1. Dependency Folders (The biggest files)
# Never upload these; they are rebuilt using 'npm install'
node_modules/
dist/
.next/
out/
build/

# 2. Environment Secrets (The most important)
# This is where you will eventually store database passwords or keys
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 3. Operating System / Tool Junk
.DS_Store
Thumbs.db
.cursor/                # Only if you don't want to share Cursor's internal settings
.vscode/                # Individual editor settings

# 4. Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm